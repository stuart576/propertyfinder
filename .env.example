# Microsoft Graph API (M365 Shared Mailbox)
GRAPH_TENANT_ID=your-tenant-id-here
GRAPH_CLIENT_ID=your-client-id-here
GRAPH_CLIENT_SECRET=your-client-secret-here
GRAPH_MAILBOX=property-alerts@yourdomain.co.uk

# Check interval (seconds) — 3600 = hourly
CHECK_INTERVAL=3600

# Filter criteria
MAX_PRICE=850000
MIN_BEDROOMS=3
MIN_ACRES=2.0

# Dashboard
WEB_PORT=8585

# Anthropic API — used to AI-classify listings (property type, acres)
# when the heuristic can't determine it from the title/description.
# Without this, the heuristic still runs but no AI fallback is performed.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
